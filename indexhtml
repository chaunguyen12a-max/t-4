function hienToast(msg, thoiGian) {
  var toast = document.getElementById('toast');
  if (!toast) return;
  toast.textContent = msg;
  toast.style.opacity = '1';
  toast.style.transform = 'translateX(-50%) translateY(0)';
  var tg = thoiGian || 2500;
  setTimeout(function() {
    toast.style.opacity = '0';
    toast.style.transform = 'translateX(-50%) translateY(80px)';
  }, tg);
}

/* =============================================
   RENDER MÓN ĂN
============================================= */
function renderMon(filter, soBatDau, soHienThi) {
  var luoi = document.getElementById('luoi-mon');
  if (!luoi) return;

  var f = filter || 'tat-ca';
  var dsLoc = f === 'tat-ca' ? dsMon : dsMon.filter(function(m) { return m.danh === f; });

  var sb = soBatDau || 0;
  var sh = soHienThi || App.soHienThi;
  var dsCat = dsLoc.slice(0, sh);

  if (dsCat.length === 0) {
    luoi.innerHTML = '<div class="khong-ket-qua"><div class="icon-lon">🍽️</div><p>Không tìm thấy món ăn phù hợp</p></div>';
    return;
  }

  var html = '';
  dsCat.forEach(function(mon, idx) {
    var delay = (idx % 4) * 0.08;
    html += '<div class="the-mon lo-ra" style="transition-delay:' + delay + 's" role="listitem" tabindex="0" data-id="' + mon.id + '" aria-label="' + mon.ten + '">';
    html += '<div class="the-mon-anh">';
    html += '<img src="' + mon.anh + '" alt="' + mon.ten + '" loading="lazy">';
    html += '<span class="nhan-mon">' + mon.nhan + '</span>';
    html += '<span class="sao-mon">⭐ ' + mon.sao + '</span>';
    html += '</div>';
    html += '<div class="the-mon-noi-dung">';
    html += '<div class="the-mon-ten">' + mon.ten + '</div>';
    html += '<div class="the-mon-mo-ta">' + mon.mo_ta + '</div>';
    html += '<div class="the-mon-footer">';
    html += '<div class="the-mon-vung">📍 ' + mon.vung + '</div>';
    html += '<button class="btn-chi-tiet" data-id="' + mon.id + '" aria-label="Xem chi tiết ' + mon.ten + '">Chi tiết</button>';
    html += '</div>';
    html += '</div>';
    html += '</div>';
  });

  luoi.innerHTML = html;

  // Cập nhật nút xem thêm
  var btnXemThem = document.getElementById('btn-xem-them');
  if (btnXemThem) {
    if (dsCat.length < dsLoc.length) {
      btnXemThem.style.display = 'inline-flex';
      btnXemThem.textContent = 'Xem thêm ' + (dsLoc.length - dsCat.length) + ' món ↓';
    } else {
      btnXemThem.style.display = 'none';
    }
  }

  // Gắn event sau khi render
  luoi.querySelectorAll('.the-mon').forEach(function(the) {
    the.addEventListener('click', function() {
      var id = parseInt(this.dataset.id, 10);
      moModal(id);
    });
    the.addEventListener('keypress', function(e) {
      if (e.key === 'Enter') {
        var id = parseInt(this.dataset.id, 10);
        moModal(id);
      }
    });
  });

  luoi.querySelectorAll('.btn-chi-tiet').forEach(function(btn) {
    btn.addEventListener('click', function(e) {
      e.stopPropagation();
      var id = parseInt(this.dataset.id, 10);
      moModal(id);
    });
  });

  // Chạy lại reveal
  setTimeout(kichHoatReveal, 50);
}

