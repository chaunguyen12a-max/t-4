      vb.classList.remove('hien');
      vb.setAttribute('aria-hidden', 'true');
      document.body.classList.remove('khoa-cuon');
    }
  });
  document.querySelectorAll('#form-lien-he input, #form-lien-he textarea').forEach(function(el) {
    el.addEventListener('focus', function() {
      this.style.borderColor = 'var(--do)';
    });
    el.addEventListener('blur', function() {
      this.style.borderColor = 'var(--vien)';
    });
  });

  // Resize: responsive lại grid liên hệ
  function capNhatGridLienHe() {
    var khung = document.getElementById('khung-lien-he');
    if (!khung) return;
    if (window.innerWidth <= 768) {
      khung.style.gridTemplateColumns = '1fr';
    } else {
      khung.style.gridTemplateColumns = '1fr 1fr';
    }
  }
  window.addEventListener('resize', debounce(capNhatGridLienHe, 150));
  capNhatGridLienHe();
}

// Chạy khi DOM sẵn sàng
if (document.readyState === 'loading') {
  document.addEventListener('DOMContentLoaded', khoiTao);
} else {
  khoiTao();
}
</script>
</body>
</html>
