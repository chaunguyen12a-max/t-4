<!DOCTYPE html>
<html lang="vi" data-theme="light">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>AnGiang Food — Tinh Hoa Ẩm Thực Miền Sông Nước</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:ital,wght@0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,400&display=swap" rel="stylesheet">
  <style>
    /* =============================================
       BIẾN CSS & THEME
    ============================================= */
    :root {
      --do: #c62828;
      --do-dam: #8e0000;
      --do-nhat: #ef5350;
      --cam: #d97706;
      --cam-nhat: #fbbf24;
      --trang: #ffffff;
      --xam-sang: #f5f5f5;
      --xam: #e0e0e0;
      --den-nhat: #212121;
      --den: #111111;
      --xanh-la: #2e7d32;

      --bg: #ffffff;
      --bg-alt: #fafafa;
      --bg-card: #ffffff;
      --chu: #212121;
      --chu-phu: #616161;
      --vien: #e0e0e0;
      --bong: 0 2px 8px rgba(0,0,0,0.08);
      --bong-hover: 0 8px 32px rgba(0,0,0,0.16);
      --nav-bg: rgba(255,255,255,0.97);
      --overlay: rgba(0,0,0,0.6);

      --chuyen: all 0.3s cubic-bezier(0.4,0,0.2,1);
      --radius: 12px;
      --radius-lg: 20px;
    }

    [data-theme="dark"] {
      --bg: #121212;
      --bg-alt: #1e1e1e;
      --bg-card: #2a2a2a;
      --chu: #f5f5f5;
      --chu-phu: #bdbdbd;
      --vien: #3a3a3a;
      --bong: 0 2px 8px rgba(0,0,0,0.4);
      --bong-hover: 0 8px 32px rgba(0,0,0,0.6);
      --nav-bg: rgba(18,18,18,0.97);
    }

    /* =============================================
       RESET
    ============================================= */
    *, *::before, *::after { margin:0; padding:0; box-sizing:border-box; }
    html { scroll-behavior:smooth; font-size:16px; }
    body {
      font-family:'Be Vietnam Pro',sans-serif;
      background:var(--bg);
      color:var(--chu);
      line-height:1.6;
      transition:background 0.3s,color 0.3s;
      overflow-x:hidden;
    }
    body.khoa-cuon { overflow:hidden; }
    a { text-decoration:none; color:inherit; }
    ul { list-style:none; }
    img { max-width:100%; display:block; }
    button { cursor:pointer; font-family:inherit; border:none; outline:none; background:none; }

    /* =============================================
       LOADING SCREEN
    ============================================= */
    #man-tai {
      position:fixed; inset:0;
      background:#c62828;
      display:flex; flex-direction:column;
      align-items:center; justify-content:center;
      z-index:9999;
      transition:opacity 0.6s ease, visibility 0.6s ease;
    }
    #man-tai.an {
      opacity:0; visibility:hidden;
    }
    .spinner {
      width:56px; height:56px;
      border:4px solid rgba(255,255,255,0.3);
      border-top-color:#fff;
      border-radius:50%;
      animation:quay 0.9s linear infinite;
      margin-bottom:20px;
    }
    @keyframes quay { to { transform:rotate(360deg); } }
    .chu-tai {
      color:#fff;
      font-size:1.2rem;
      font-weight:700;
      letter-spacing:0.2em;
      text-transform:uppercase;
    }
    .diem-tai {
      display:flex; gap:6px; margin-top:12px;
    }
    .diem-tai span {
      width:8px; height:8px;
      background:rgba(255,255,255,0.6);
      border-radius:50%;
      animation:nhip 1.2s ease-in-out infinite;
    }
    .diem-tai span:nth-child(2) { animation-delay:0.2s; }
    .diem-tai span:nth-child(3) { animation-delay:0.4s; }
    @keyframes nhip { 0%,80%,100%{opacity:0.3;transform:scale(0.8)} 40%{opacity:1;transform:scale(1.2)} }

    /* =============================================
       CONTAINER
    ============================================= */
    .container {
      width:100%;
      max-width:1200px;
      margin:0 auto;
      padding:0 20px;
    }

    /* =============================================
       TOPBAR (trên header)
    ============================================= */
    .topbar {
      background:var(--do);
      color:#fff;
      font-size:0.8rem;
      padding:6px 0;
    }
    .topbar-inner {
      display:flex;
      align-items:center;
      justify-content:space-between;
    }
    .topbar-left { display:flex; gap:20px; align-items:center; }
    .topbar-left span { display:flex; align-items:center; gap:4px; }
    .topbar-right { display:flex; gap:16px; align-items:center; }
    .topbar a { color:#fff; opacity:0.85; }
    .topbar a:hover { opacity:1; }

    /* =============================================
       HEADER & NAV
    ============================================= */
    #header {
      position:sticky; top:0; z-index:1000;
      background:var(--nav-bg);
      backdrop-filter:blur(12px);
      -webkit-backdrop-filter:blur(12px);
      border-bottom:1px solid var(--vien);
      box-shadow:var(--bong);
      transition:var(--chuyen);
    }
    .nav-container {
      display:flex;
      align-items:center;
      height:64px;
      gap:24px;
    }
    .logo {
      font-size:1.5rem;
      font-weight:900;
      letter-spacing:-0.03em;
      white-space:nowrap;
      color:var(--do);
      flex-shrink:0;
    }
    .logo span { color:var(--cam); }

    /* Thanh tìm kiếm */
    .thanh-tim {
      flex:1;
      max-width:480px;
      position:relative;
    }
    .thanh-tim input {
      width:100%;
      padding:10px 44px 10px 16px;
      border:2px solid var(--vien);
      border-radius:50px;
      background:var(--bg-alt);
      color:var(--chu);
      font-family:inherit;
      font-size:0.9rem;
      transition:var(--chuyen);
    }
    .thanh-tim input:focus {
      outline:none;
      border-color:var(--do);
      background:var(--bg);
    }
    .btn-tim {
      position:absolute; right:12px; top:50%;
      transform:translateY(-50%);
      color:var(--chu-phu);
      font-size:1rem;
      transition:color 0.2s;
    }
    .btn-tim:hover { color:var(--do); }

    /* Nav links */
    .nav-links {
      display:flex;
      align-items:center;
      gap:4px;
      margin-left:auto;
    }
    .nav-link {
      padding:8px 14px;
      border-radius:8px;
      font-size:0.9rem;
      font-weight:500;
      color:var(--chu);
      transition:var(--chuyen);
      white-space:nowrap;
    }
    .nav-link:hover, .nav-link.active {
      background:var(--do);
      color:#fff;
    }

    /* Actions bên phải */
    .nav-actions {
      display:flex;
      align-items:center;
      gap:8px;
      flex-shrink:0;
    }
    .btn-theme {
      width:38px; height:38px;
      border-radius:50%;
      border:2px solid var(--vien);
      background:var(--bg-alt);
      color:var(--chu);
      font-size:1rem;
      display:flex; align-items:center; justify-content:center;
      transition:var(--chuyen);
    }
    .btn-theme:hover { border-color:var(--do); color:var(--do); }

    .btn-cta {
      padding:9px 20px;
      background:var(--do);
      color:#fff;
      border-radius:8px;
      font-weight:700;
      font-size:0.85rem;
      transition:var(--chuyen);
      white-space:nowrap;
    }
    .btn-cta:hover { background:var(--do-dam); transform:translateY(-1px); }

    .hamburger {
      display:none;
      width:38px; height:38px;
      flex-direction:column;
      justify-content:center;
      align-items:center;
      gap:5px;
      border-radius:8px;
      border:2px solid var(--vien);
      background:var(--bg-alt);
    }
    .hamburger span {
      display:block;
      width:20px; height:2px;
      background:var(--chu);
      border-radius:2px;
      transition:var(--chuyen);
    }
    .hamburger.mo span:nth-child(1) { transform:translateY(7px) rotate(45deg); }
    .hamburger.mo span:nth-child(2) { opacity:0; }
    .hamburger.mo span:nth-child(3) { transform:translateY(-7px) rotate(-45deg); }

    /* Menu mobile */
    .mobile-menu {
      display:none;
      position:fixed;
      top:64px; left:0; right:0; bottom:0;
      background:var(--bg);
      z-index:999;
      padding:24px 20px;
      overflow-y:auto;
      transform:translateX(100%);
      transition:transform 0.3s ease;
    }
    .mobile-menu.mo {
      display:block;
      transform:translateX(0);
    }
    .mobile-menu .nav-link {
      display:block;
      padding:14px 16px;
      border-bottom:1px solid var(--vien);
      font-size:1rem;
      border-radius:0;
    }
    .mobile-menu .nav-link:last-child { border-bottom:none; }

    /* Kết quả tìm kiếm */
    #ket-qua-tim {
      position:absolute;
      top:calc(100% + 8px);
      left:0; right:0;
      background:var(--bg-card);
      border:1px solid var(--vien);
      border-radius:var(--radius);
      box-shadow:var(--bong-hover);
      z-index:500;
      overflow:hidden;
      max-height:400px;
      overflow-y:auto;
      display:none;
    }
    #ket-qua-tim.hien { display:block; }
    .item-tim {
      display:flex; align-items:center; gap:12px;
      padding:12px 16px;
      cursor:pointer;
      transition:background 0.2s;
    }
    .item-tim:hover { background:var(--bg-alt); }
    .item-tim-anh {
      width:48px; height:48px;
      border-radius:8px;
      background:var(--xam-sang);
      overflow:hidden; flex-shrink:0;
    }
    .item-tim-anh img { width:100%; height:100%; object-fit:cover; }
    .item-tim-ten { font-weight:600; font-size:0.9rem; }
    .item-tim-tag { font-size:0.75rem; color:var(--do); }
    .tim-rong {
      padding:24px; text-align:center;
      color:var(--chu-phu); font-size:0.9rem;
    }

    /* =============================================
       HERO SECTION
    ============================================= */
    .hero {
      position:relative;
      height:100vh;
      min-height:600px;
      overflow:hidden;
    }
    .hero-slides { position:relative; height:100%; }
    .hero-slide {
      position:absolute; inset:0;
      opacity:0;
      transition:opacity 0.8s ease;
    }
    .hero-slide.active { opacity:1; }
    .hero-slide-bg {
      width:100%; height:100%;
      background-size:cover;
      background-position:center;
      transform:scale(1.05);
      transition:transform 8s ease;
    }
    .hero-slide.active .hero-slide-bg { transform:scale(1); }
    .hero-overlay {
      position:absolute; inset:0;
      background:linear-gradient(
        135deg,
        rgba(140,0,0,0.75) 0%,
        rgba(0,0,0,0.5) 50%,
        rgba(0,0,0,0.3) 100%
      );
    }
    .hero-content {
      position:absolute; inset:0;
      display:flex; flex-direction:column;
      justify-content:center;
      padding:0 0 0 8%;
      max-width:680px;
    }
    .hero-badge {
      display:inline-flex; align-items:center; gap:8px;
      background:var(--cam);
      color:#fff;
      padding:6px 16px;
      border-radius:50px;
      font-size:0.8rem;
      font-weight:700;
      letter-spacing:0.05em;
      text-transform:uppercase;
      margin-bottom:20px;
      width:fit-content;
    }
    .hero-tieu-de {
      font-size:clamp(2rem, 5vw, 3.8rem);
      font-weight:900;
      color:#fff;
      line-height:1.15;
      margin-bottom:16px;
      text-shadow:0 2px 20px rgba(0,0,0,0.3);
    }
    .hero-tieu-de span { color:var(--cam-nhat); }
    .hero-mo-ta {
      font-size:1.05rem;
      color:rgba(255,255,255,0.88);
      margin-bottom:32px;
      max-width:480px;
      line-height:1.7;
    }
    .hero-buttons { display:flex; gap:16px; flex-wrap:wrap; }
    .btn-hero-chinh {
      padding:14px 32px;
      background:var(--do);
      color:#fff;
      border-radius:8px;
      font-weight:700;
      font-size:1rem;
      transition:var(--chuyen);
      border:2px solid var(--do);
    }
    .btn-hero-chinh:hover {
      background:var(--do-dam);
      border-color:var(--do-dam);
      transform:translateY(-2px);
      box-shadow:0 8px 24px rgba(198,40,40,0.4);
    }
    .btn-hero-phu {
      padding:14px 32px;
      background:transparent;
      color:#fff;
      border-radius:8px;
      font-weight:600;
      font-size:1rem;
      transition:var(--chuyen);
      border:2px solid rgba(255,255,255,0.6);
    }
    .btn-hero-phu:hover {
      background:rgba(255,255,255,0.15);
      border-color:#fff;
    }

    /* Chỉ báo slide */
    .hero-dots {
      position:absolute;
      bottom:32px; left:50%;
      transform:translateX(-50%);
      display:flex; gap:8px;
      z-index:10;
    }
    .hero-dot {
      width:8px; height:8px;
      border-radius:50%;
      background:rgba(255,255,255,0.4);
      cursor:pointer;
      transition:var(--chuyen);
    }
    .hero-dot.active {
      background:#fff;
      width:24px;
      border-radius:4px;
    }

    /* Mũi tên cuộn */
    .hero-scroll {
      position:absolute;
      bottom:32px; right:40px;
      display:flex; flex-direction:column;
      align-items:center; gap:6px;
      color:rgba(255,255,255,0.7);
      font-size:0.75rem;
      letter-spacing:0.1em;
      text-transform:uppercase;
      animation:nhunBay 2s ease-in-out infinite;
      cursor:pointer;
    }
    @keyframes nhunBay { 0%,100%{transform:translateY(0)} 50%{transform:translateY(8px)} }
    .hero-scroll-line {
      width:1px; height:40px;
      background:linear-gradient(to bottom,rgba(255,255,255,0.7),transparent);
    }

    /* =============================================
       THANH CATEGORY (KFC-style)
    ============================================= */
    .category-bar {
      background:var(--do);
      padding:0;
      position:sticky;
      top:64px;
      z-index:900;
    }
    .category-scroll {
      display:flex;
      overflow-x:auto;
      gap:0;
      scrollbar-width:none;
    }
    .category-scroll::-webkit-scrollbar { display:none; }
    .cat-btn {
      display:flex; flex-direction:column;
      align-items:center; gap:4px;
      padding:12px 20px;
      color:rgba(255,255,255,0.75);
      font-size:0.8rem;
      font-weight:600;
      white-space:nowrap;
      transition:var(--chuyen);
      border-bottom:3px solid transparent;
      flex-shrink:0;
    }
    .cat-btn:hover, .cat-btn.active {
      color:#fff;
      border-bottom-color:var(--cam-nhat);
      background:rgba(255,255,255,0.1);
    }
    .cat-btn .icon { font-size:1.3rem; }

    /* =============================================
       SECTION CHUNG
    ============================================= */
    section { padding:80px 0; }
    .tieu-de-section {
      text-align:center;
      margin-bottom:48px;
    }
    .nhan-section {
      display:inline-block;
      background:rgba(198,40,40,0.1);
      color:var(--do);
      padding:4px 14px;
      border-radius:50px;
      font-size:0.8rem;
      font-weight:700;
      letter-spacing:0.06em;
      text-transform:uppercase;
      margin-bottom:12px;
    }
    .tieu-de-section h2 {
      font-size:clamp(1.6rem, 4vw, 2.5rem);
      font-weight:900;
      color:var(--chu);
      margin-bottom:12px;
    }
    .tieu-de-section p {
      color:var(--chu-phu);
      max-width:560px;
      margin:0 auto;
      font-size:1rem;
    }

    /* =============================================
       GRID MÓN ĂN (KFC Menu-style)
    ============================================= */
    #mon-an { background:var(--bg-alt); }
    .luoi-mon {
      display:grid;
      grid-template-columns:repeat(4, 1fr);
      gap:24px;
    }
    /* Filter tabs */
    .filter-tabs {
      display:flex;
      flex-wrap:wrap;
      gap:8px;
      margin-bottom:32px;
      justify-content:center;
    }
    .filter-tab {
      padding:8px 20px;
      border-radius:50px;
      border:2px solid var(--vien);
      font-size:0.85rem;
      font-weight:600;
      color:var(--chu-phu);
      background:var(--bg-card);
      transition:var(--chuyen);
    }
    .filter-tab:hover { border-color:var(--do); color:var(--do); }
    .filter-tab.active {
      background:var(--do);
      border-color:var(--do);
      color:#fff;
    }

    /* Card món ăn */
    .the-mon {
      background:var(--bg-card);
      border-radius:var(--radius-lg);
      overflow:hidden;
      box-shadow:var(--bong);
      transition:var(--chuyen);
      cursor:pointer;
      position:relative;
    }
    .the-mon:hover {
      transform:translateY(-6px);
      box-shadow:var(--bong-hover);
    }
    .the-mon-anh {
      position:relative;
      overflow:hidden;
      aspect-ratio:4/3;
      background:var(--xam);
    }
    .the-mon-anh img {
      width:100%; height:100%;
      object-fit:cover;
      transition:transform 0.5s ease;
    }
    .the-mon:hover .the-mon-anh img { transform:scale(1.08); }
    .nhan-mon {
      position:absolute; top:12px; left:12px;
      background:var(--do);
      color:#fff;
      font-size:0.7rem;
      font-weight:700;
      padding:3px 10px;
      border-radius:50px;
      text-transform:uppercase;
      letter-spacing:0.05em;
    }
    .nhan-mon.moi { background:var(--xanh-la); }
    .nhan-mon.hot { background:#ff6d00; }
    .sao-mon {
      position:absolute; bottom:12px; right:12px;
      background:rgba(0,0,0,0.65);
      color:#ffd600;
      font-size:0.75rem;
      font-weight:700;
      padding:4px 10px;
      border-radius:50px;
      backdrop-filter:blur(4px);
    }
    .the-mon-noi-dung {
      padding:16px;
    }
    .the-mon-ten {
      font-size:1rem;
      font-weight:700;
      color:var(--chu);
      margin-bottom:6px;
      line-height:1.3;
    }
    .the-mon-mo-ta {
      font-size:0.82rem;
      color:var(--chu-phu);
      line-height:1.5;
      margin-bottom:12px;
      display:-webkit-box;
      -webkit-line-clamp:2;
      -webkit-box-orient:vertical;
      overflow:hidden;
    }
    .the-mon-footer {
      display:flex; align-items:center;
      justify-content:space-between;
    }
    .the-mon-vung {
      font-size:0.75rem;
      color:var(--chu-phu);
      display:flex; align-items:center; gap:4px;
    }
    .btn-chi-tiet {
      padding:7px 16px;
      background:var(--do);
      color:#fff;
      border-radius:8px;
      font-size:0.8rem;
      font-weight:700;
      transition:var(--chuyen);
    }
    .btn-chi-tiet:hover {
      background:var(--do-dam);
      transform:scale(1.04);
    }
    .khong-ket-qua {
      grid-column:1/-1;
      text-align:center;
      padding:60px 20px;
      color:var(--chu-phu);
    }
    .khong-ket-qua .icon-lon { font-size:3rem; margin-bottom:12px; }

    /* =============================================
       FEATURED — 3 cột nổi bật
    ============================================= */
    #noi-bat { background:var(--bg); }
    .luoi-noi-bat {
      display:grid;
      grid-template-columns:1.4fr 1fr 1fr;
      grid-template-rows:1fr 1fr;
      gap:16px;
      min-height:480px;
    }
    .the-noi-bat {
      position:relative;
      border-radius:var(--radius-lg);
      overflow:hidden;
      cursor:pointer;
    }
    .the-noi-bat:first-child {
      grid-row:span 2;
    }
    .the-noi-bat-bg {
      width:100%; height:100%;
      background-size:cover;
      background-position:center;
      transition:transform 0.6s ease;
    }
    .the-noi-bat:hover .the-noi-bat-bg { transform:scale(1.05); }
    .the-noi-bat-overlay {
      position:absolute; inset:0;
      background:linear-gradient(to top, rgba(0,0,0,0.75) 0%, transparent 55%);
      display:flex; flex-direction:column;
      justify-content:flex-end;
      padding:24px;
    }
    .the-noi-bat-ten {
      font-size:1.2rem;
      font-weight:800;
      color:#fff;
      margin-bottom:4px;
    }
    .the-noi-bat:first-child .the-noi-bat-ten { font-size:1.6rem; }
    .the-noi-bat-mo-ta {
      font-size:0.85rem;
      color:rgba(255,255,255,0.8);
      line-height:1.5;
    }
    .the-noi-bat-tag {
      display:inline-block;
      background:var(--cam);
      color:#fff;
      font-size:0.7rem;
      font-weight:700;
      padding:3px 10px;
      border-radius:50px;
      margin-bottom:8px;
      text-transform:uppercase;
      letter-spacing:0.05em;
    }

    /* =============================================
       LỄ HỘI (KFC Promotion style)
    ============================================= */
    #le-hoi { background:var(--do); position:relative; overflow:hidden; }
    #le-hoi::before {
      content:'';
      position:absolute; inset:0;
      background:url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.05'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
