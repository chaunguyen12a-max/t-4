                if(loader) {
                    loader.style.opacity = '0';
                    setTimeout(() => {
                        loader.style.visibility = 'hidden';
                        document.body.classList.remove('no-scroll');
                    }, 500);
                }
            }, 1500);

            // --- 2. Dark Mode Toggle ---
            const themeBtn = document.getElementById('theme-toggle');
            // Check local storage
            if (localStorage.getItem('theme') === 'dark') {
                document.body.classList.add('dark-mode');
                if(themeBtn) themeBtn.textContent = '☀️';
            }
            if(themeBtn) {
                themeBtn.addEventListener('click', () => {
                    document.body.classList.toggle('dark-mode');
                    const isDark = document.body.classList.contains('dark-mode');
                    themeBtn.textContent = isDark ? '☀️' : '🌙';
                    localStorage.setItem('theme', isDark ? 'dark' : 'light');
                });
            }

            // --- 3. Mobile Hamburger Menu ---
            const hamburger = document.getElementById('hamburger');
            const navLinksMenu = document.getElementById('nav-links');
            const navLinks = document.querySelectorAll('.nav-link');

            if(hamburger && navLinksMenu) {
                hamburger.addEventListener('click', () => {
                    navLinksMenu.classList.toggle('active');
                    hamburger.textContent = navLinksMenu.classList.contains('active') ? '✖' : '☰';
                });

                // Close menu when clicking a link
                navLinks.forEach(link => {
                    link.addEventListener('click', () => {
                        navLinksMenu.classList.remove('active');
                        hamburger.textContent = '☰';
                    });
                });
            }

            // --- 4. Sticky Navbar & Back to Top ---
            const header = document.getElementById('header');
            const backToTop = document.getElementById('back-to-top');

            window.addEventListener('scroll', () => {
                const scrollY = window.scrollY;
                // Navbar
                if(header) {
                    if (scrollY > 50) header.classList.add('sticky');
                    else header.classList.remove('sticky');
                }
                // Back to top
                if(backToTop) {
                    if (scrollY > 500) backToTop.classList.add('show');
                    else backToTop.classList.remove('show');
                }
            });

            if(backToTop) {
                backToTop.addEventListener('click', () => {
                    window.scrollTo({ top: 0, behavior: 'smooth' });
                });
            }

            // --- 5. Scroll Reveal Animation (Intersection Observer) ---
            const reveals = document.querySelectorAll('.reveal');
            const revealOptions = {
                threshold: 0.15,
                rootMargin: "0px 0px -50px 0px"
            };

            const revealOnScroll = new IntersectionObserver((entries, observer) => {
                entries.forEach(entry => {
                    if (entry.isIntersecting) {
                        entry.target.classList.add('active');
                        observer.unobserve(entry.target); // Chạy 1 lần
                    }
                });
            }, revealOptions);

            reveals.forEach(reveal => {
                revealOnScroll.observe(reveal);
            });

            // --- 6. Number Counter Animation ---
            const counters = document.querySelectorAll('.counter');
            let hasCounted = false;

            const countUp = () => {
                counters.forEach(counter => {
                    const target = +counter.getAttribute('data-target');
                    const speed = 200; // Tốc độ đếm
                    const updateCount = () => {
                        const count = +counter.innerText;
                        const inc = target / speed;
                        if (count < target) {
                            counter.innerText = Math.ceil(count + inc);
                            setTimeout(updateCount, 15);
                        } else {
                            counter.innerText = target;
                        }
                    };
                    updateCount();
                });
            };

            const statsSection = document.getElementById('stats');
            if(statsSection) {
                const counterObserver = new IntersectionObserver((entries) => {
                    const entry = entries[0];
                    if(entry.isIntersecting && !hasCounted) {
                        countUp();
                        hasCounted = true;
                    }
                }, { threshold: 0.5 });
                counterObserver.observe(statsSection);
            }

            // --- 7. Food Detail Modal Logic ---
            const foodModal = document.getElementById('food-modal');
            const closeFoodBtn = document.getElementById('close-food-modal');
            const detailButtons = document.querySelectorAll('.btn-detail');

            // Modal Elements
            const mTitle = document.getElementById('modal-title');
            const mImg = document.getElementById('modal-img');
            const mDesc = document.getElementById('modal-desc');
            const mOrigin = document.getElementById('modal-origin');
            const mRecipe = document.getElementById('modal-recipe');

            if(detailButtons.length > 0 && foodModal) {
                detailButtons.forEach(btn => {
                    btn.addEventListener('click', (e) => {
                        e.preventDefault();
                        // Get data
                        const { name, img, desc, origin, recipe } = btn.dataset;
                        // Set data
                        mTitle.textContent = name || 'Chưa cập nhật';
                        mImg.src = img || '';
                        mDesc.textContent = desc || '';
                        mOrigin.textContent = origin || '';
                        mRecipe.textContent = recipe || '';
                        
                        // Show Modal
                        foodModal.classList.add('active');
                        document.body.classList.add('no-scroll');
                    });
                });

                // Close Logic
                const closeFoodModal = () => {
                    foodModal.classList.remove('active');
                    document.body.classList.remove('no-scroll');
                };

                closeFoodBtn.addEventListener('click', closeFoodModal);
                
                // Click outside to close
                foodModal.addEventListener('click', (e) => {
                    if (e.target === foodModal) closeFoodModal();
                });
            }

            // --- 8. Gallery Fullscreen Modal ---
            const galleryModal = document.getElementById('gallery-modal');
            const galleryImgFull = document.getElementById('gallery-full-img');
            const closeGalleryBtn = document.getElementById('close-gallery-modal');
            const galleryItems = document.querySelectorAll('.gallery-item');

            if(galleryItems.length > 0 && galleryModal) {
                galleryItems.forEach(item => {
                    item.addEventListener('click', () => {
                        const imgSrc = item.getAttribute('data-img');
                        galleryImgFull.src = imgSrc;
                        galleryModal.classList.add('active');
                        document.body.classList.add('no-scroll');
                    });
                });

                const closeGalleryModal = () => {
                    galleryModal.classList.remove('active');
                    document.body.classList.remove('no-scroll');
                };

                closeGalleryBtn.addEventListener('click', closeGalleryModal);
                galleryModal.addEventListener('click', (e) => {
                    if(e.target === galleryModal) closeGalleryModal();
                });
            }

            // --- 9. Fake Form Submission ---
            const contactForm = document.getElementById('contact-form');
            const formMessage = document.getElementById('form-message');

            if(contactForm) {
                contactForm.addEventListener('submit', (e) => {
                    e.preventDefault(); // Prevent page reload
                    
                    const btnSubmit = contactForm.querySelector('.btn-submit');
                    const originalText = btnSubmit.textContent;
                    
                    // Button UI loading state
                    btnSubmit.textContent = 'Đang gửi...';
                    btnSubmit.disabled = true;

                    // Fake network request
                    setTimeout(() => {
                        formMessage.style.display = 'block';
                        contactForm.reset();
                        btnSubmit.textContent = originalText;
                        btnSubmit.disabled = false;
                        
                        // Hide message after 5s
                        setTimeout(() => {
                            formMessage.style.display = 'none';
                        }, 5000);
                    }, 1000);
                });
            }
        });
    </script>
</body>
</html>
