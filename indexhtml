      font-weight:900;
      color:var(--do);
      line-height:1;
      margin-bottom:8px;
    }
    .thong-ke-ten {
      font-size:0.9rem;
      color:var(--chu-phu);
      font-weight:500;
    }

    /* =============================================
       STORY / PARALLAX
    ============================================= */
    #cau-chuyen {
      position:relative;
      min-height:600px;
      display:flex; align-items:center;
      overflow:hidden;
    }
    .cau-chuyen-bg {
      position:absolute; inset:0;
      background-image:url('https://images.unsplash.com/photo-1559847844-5315695dadae?w=1600&q=80');
      background-size:cover;
      background-position:center;
      background-attachment:fixed;
    }
    .cau-chuyen-overlay {
      position:absolute; inset:0;
      background:linear-gradient(135deg,rgba(140,0,0,0.85),rgba(0,0,0,0.7));
    }
    .cau-chuyen-noi-dung {
      position:relative; z-index:1;
      max-width:620px;
      padding:80px 0;
    }
    .cau-chuyen-nhan {
      display:inline-block;
      background:var(--cam);
      color:#fff;
      padding:5px 16px;
      border-radius:50px;
      font-size:0.8rem;
      font-weight:700;
      text-transform:uppercase;
      letter-spacing:0.06em;
      margin-bottom:20px;
    }
    .cau-chuyen-tieu-de {
      font-size:clamp(1.8rem, 4vw, 2.8rem);
      font-weight:900;
      color:#fff;
      line-height:1.2;
      margin-bottom:20px;
    }
    .cau-chuyen-tieu-de span { color:var(--cam-nhat); }
    .cau-chuyen-van-ban {
      color:rgba(255,255,255,0.85);
      font-size:1rem;
      line-height:1.8;
      margin-bottom:24px;
    }
    .cau-chuyen-dac-diem {
      display:flex; flex-direction:column; gap:12px;
      margin-bottom:32px;
    }
    .cau-chuyen-item {
      display:flex; align-items:center; gap:12px;
      color:rgba(255,255,255,0.9);
      font-size:0.9rem;
    }
    .cau-chuyen-item .icon {
      width:36px; height:36px;
      background:rgba(255,255,255,0.15);
      border-radius:50%;
      display:flex; align-items:center; justify-content:center;
      font-size:1.1rem;
      flex-shrink:0;
    }
    .btn-cau-chuyen {
      display:inline-flex; align-items:center; gap:8px;
      padding:13px 28px;
      background:var(--cam);
      color:#fff;
      border-radius:8px;
      font-weight:700;
      font-size:0.95rem;
      transition:var(--chuyen);
    }
    .btn-cau-chuyen:hover {
      background:#b45309;
      transform:translateY(-2px);
      box-shadow:0 8px 24px rgba(217,119,6,0.4);
    }

    /* =============================================
       ĐỊA ĐIỂM
    ============================================= */
    #dia-diem { background:var(--bg); }
    .luoi-dia-diem {
      display:grid;
      grid-template-columns:repeat(3,1fr);
      gap:24px;
    }
    .the-dia-diem {
      background:var(--bg-card);
      border-radius:var(--radius-lg);
      overflow:hidden;
      box-shadow:var(--bong);
      transition:var(--chuyen);
      cursor:pointer;
    }
    .the-dia-diem:hover {
      transform:translateY(-4px);
      box-shadow:var(--bong-hover);
    }
    .the-dia-diem-anh {
      aspect-ratio:16/9;
      overflow:hidden;
      background:var(--xam);
    }
    .the-dia-diem-anh img {
      width:100%; height:100%;
      object-fit:cover;
      transition:transform 0.5s ease;
    }
    .the-dia-diem:hover .the-dia-diem-anh img { transform:scale(1.05); }
    .the-dia-diem-noi-dung { padding:20px; }
    .the-dia-diem-ten {
      font-size:1rem;
      font-weight:700;
      margin-bottom:6px;
    }
    .the-dia-diem-dia-chi {
      font-size:0.82rem;
      color:var(--chu-phu);
      display:flex; align-items:flex-start; gap:6px;
      line-height:1.5;
      margin-bottom:12px;
    }
    .the-dia-diem-footer {
      display:flex; align-items:center;
      justify-content:space-between;
      padding-top:12px;
      border-top:1px solid var(--vien);
    }
    .the-dia-diem-loai {
      font-size:0.75rem;
      color:var(--do);
      font-weight:700;
      background:rgba(198,40,40,0.1);
      padding:3px 10px;
      border-radius:50px;
    }
    .the-dia-diem-danh-gia {
      font-size:0.8rem;
      color:#ffa000;
      font-weight:600;
    }

    /* =============================================
       BLOG
    ============================================= */
    #blog { background:var(--bg-alt); }
    .luoi-blog {
      display:grid;
      grid-template-columns:repeat(3,1fr);
      gap:24px;
    }
    .the-blog {
      background:var(--bg-card);
      border-radius:var(--radius-lg);
      overflow:hidden;
      box-shadow:var(--bong);
      transition:var(--chuyen);
    }
    .the-blog:hover {
      transform:translateY(-4px);
      box-shadow:var(--bong-hover);
    }
    .the-blog-anh {
      aspect-ratio:16/9;
      overflow:hidden;
      background:var(--xam);
    }
    .the-blog-anh img {
      width:100%; height:100%;
      object-fit:cover;
      transition:transform 0.5s;
    }
    .the-blog:hover .the-blog-anh img { transform:scale(1.05); }
    .the-blog-noi-dung { padding:20px; }
    .the-blog-tag {
      display:inline-block;
      background:rgba(198,40,40,0.1);
      color:var(--do);
      font-size:0.72rem;
      font-weight:700;
      padding:3px 10px;
      border-radius:50px;
      margin-bottom:10px;
      text-transform:uppercase;
      letter-spacing:0.04em;
    }
    .the-blog-tieu-de {
      font-size:1rem;
      font-weight:700;
      margin-bottom:8px;
      line-height:1.4;
    }
    .the-blog-tom-tat {
      font-size:0.82rem;
      color:var(--chu-phu);
      line-height:1.6;
      margin-bottom:14px;
      display:-webkit-box;
      -webkit-line-clamp:3;
      -webkit-box-orient:vertical;
      overflow:hidden;
    }
    .the-blog-footer {
      display:flex; align-items:center;
      gap:12px;
      font-size:0.78rem;
      color:var(--chu-phu);
      border-top:1px solid var(--vien);
      padding-top:12px;
    }
    .the-blog-footer .sep { color:var(--vien); }

    /* =============================================
       FOOTER
    ============================================= */
    footer {
      background:var(--den-nhat);
      color:rgba(255,255,255,0.8);
      padding:0;
    }
    .footer-top {
      display:grid;
      grid-template-columns:1.4fr 1fr 1fr 1fr;
      gap:40px;
      padding:60px 0 40px;
      border-bottom:1px solid rgba(255,255,255,0.1);
    }
    .footer-logo {
      font-size:1.6rem;
      font-weight:900;
      color:#fff;
      margin-bottom:12px;
    }
    .footer-logo span { color:var(--cam); }
    .footer-mo-ta {
      font-size:0.85rem;
      line-height:1.7;
      color:rgba(255,255,255,0.6);
      margin-bottom:20px;
    }
    .footer-mxh {
      display:flex; gap:10px;
    }
    .footer-mxh a {
      width:38px; height:38px;
      border-radius:50%;
      background:rgba(255,255,255,0.1);
      display:flex; align-items:center; justify-content:center;
      font-size:1rem;
      color:#fff;
      transition:var(--chuyen);
    }
    .footer-mxh a:hover { background:var(--do); }
    .footer-tieu-de {
      font-size:0.9rem;
      font-weight:700;
      color:#fff;
      margin-bottom:20px;
      text-transform:uppercase;
      letter-spacing:0.06em;
    }
    .footer-links { display:flex; flex-direction:column; gap:10px; }
    .footer-links a {
      font-size:0.85rem;
      color:rgba(255,255,255,0.6);
      transition:color 0.2s;
    }
    .footer-links a:hover { color:var(--cam); }
    .footer-lien-he { display:flex; flex-direction:column; gap:12px; }
    .footer-lien-he-item {
      display:flex; gap:10px; align-items:flex-start;
      font-size:0.82rem;
      color:rgba(255,255,255,0.6);
    }
    .footer-lien-he-item .icon { font-size:1rem; flex-shrink:0; margin-top:2px; }
    .footer-bottom {
      padding:20px 0;
      display:flex;
      align-items:center;
      justify-content:space-between;
      font-size:0.8rem;
      color:rgba(255,255,255,0.4);
    }
    .footer-bottom a { color:rgba(255,255,255,0.5); }
    .footer-bottom a:hover { color:var(--cam); }

    /* =============================================
       MODAL CHI TIẾT MÓN ĂN
    ============================================= */
    .modal-nen {
      display:none;
      position:fixed; inset:0;
      background:rgba(0,0,0,0.75);
      z-index:2000;
      align-items:center;
      justify-content:center;
      padding:20px;
      backdrop-filter:blur(4px);
    }
    .modal-nen.hien { display:flex; }
    .modal-hop {
      background:var(--bg-card);
      border-radius:var(--radius-lg);
      overflow:hidden;
      max-width:700px;
      width:100%;
      max-height:90vh;
      overflow-y:auto;
      animation:hienModal 0.3s ease;
      position:relative;
    }
    @keyframes hienModal {
      from { opacity:0; transform:scale(0.92) translateY(20px); }
      to { opacity:1; transform:scale(1) translateY(0); }
    }
    .modal-anh {
      width:100%; aspect-ratio:16/9;
      background:var(--xam);
      overflow:hidden;
    }
    .modal-anh img { width:100%; height:100%; object-fit:cover; }
    .modal-noi-dung { padding:28px; }
    .modal-nhan {
      display:inline-block;
      background:rgba(198,40,40,0.1);
      color:var(--do);
      font-size:0.75rem;
      font-weight:700;
      padding:3px 12px;
      border-radius:50px;
      margin-bottom:12px;
    }
    .modal-ten {
      font-size:1.6rem;
      font-weight:900;
      color:var(--chu);
      margin-bottom:8px;
    }
    .modal-sao {
      color:#ffa000;
      font-size:0.9rem;
      margin-bottom:16px;
    }
    .modal-mo-ta {
      font-size:0.92rem;
      color:var(--chu-phu);
      line-height:1.8;
      margin-bottom:20px;
    }
    .modal-chi-tiet {
      display:grid;
      grid-template-columns:repeat(2,1fr);
      gap:12px;
      margin-bottom:20px;
    }
    .modal-chi-tiet-item {
      background:var(--bg-alt);
      padding:12px 16px;
      border-radius:var(--radius);
    }
    .modal-chi-tiet-nhan {
      font-size:0.72rem;
      color:var(--chu-phu);
      text-transform:uppercase;
      letter-spacing:0.06em;
      margin-bottom:4px;
    }
    .modal-chi-tiet-gia-tri {
      font-size:0.9rem;
      font-weight:600;
      color:var(--chu);
    }
    .modal-dong {
      position:absolute; top:16px; right:16px;
      width:36px; height:36px;
      background:rgba(0,0,0,0.4);
      border-radius:50%;
      color:#fff;
      display:flex; align-items:center; justify-content:center;
      font-size:1.1rem;
      transition:var(--chuyen);
    }
    .modal-dong:hover { background:var(--do); }

    /* =============================================
       REVEAL ANIMATION
    ============================================= */
    .lo-ra {
      opacity:0;
      transform:translateY(32px);
      transition:opacity 0.6s ease, transform 0.6s ease;
    }
    .lo-ra.hien-ra {
      opacity:1;
      transform:translateY(0);
    }
    .lo-ra-trai {
      opacity:0;
      transform:translateX(-32px);
      transition:opacity 0.6s ease, transform 0.6s ease;
    }
    .lo-ra-trai.hien-ra {
      opacity:1;
      transform:translateX(0);
    }

    /* =============================================
       RESPONSIVE
    ============================================= */
    @media (max-width:1200px) {
      .luoi-mon { grid-template-columns:repeat(3,1fr); }
    }

    @media (max-width:992px) {
      .nav-links { display:none; }
      .hamburger { display:flex; }
      .topbar-left span:not(:first-child) { display:none; }
      .luoi-le-hoi { grid-template-columns:repeat(2,1fr); }
      .luoi-thong-ke { grid-template-columns:repeat(2,1fr); }
      .footer-top { grid-template-columns:1fr 1fr; }
      .luoi-noi-bat {
        grid-template-columns:1fr 1fr;
        grid-template-rows:auto;
      }
      .the-noi-bat:first-child { grid-row:span 1; grid-column:span 2; }
    }

    @media (max-width:768px) {
      section { padding:56px 0; }
      .thanh-tim { display:none; }
      .topbar { display:none; }
      .luoi-mon { grid-template-columns:repeat(2,1fr); gap:16px; }
      .luoi-dia-diem { grid-template-columns:repeat(2,1fr); }
      .luoi-blog { grid-template-columns:1fr; }
      .luoi-le-hoi { grid-template-columns:1fr; }
      .luoi-noi-bat { grid-template-columns:1fr; }
      .the-noi-bat:first-child { grid-column:span 1; min-height:240px; }
      .footer-top { grid-template-columns:1fr; gap:32px; }
      .footer-bottom { flex-direction:column; gap:8px; text-align:center; }
      .hero-content { padding:0 24px; }
    }

    @media (max-width:576px) {
      .luoi-mon { grid-template-columns:1fr 1fr; gap:12px; }
      .luoi-thong-ke { grid-template-columns:repeat(2,1fr); gap:12px; }
      .luoi-dia-diem { grid-template-columns:1fr; }
      .modal-chi-tiet { grid-template-columns:1fr; }
      .hero-buttons { flex-direction:column; }
      .btn-hero-chinh, .btn-hero-phu { width:100%; text-align:center; }
    }

    @media (max-width:360px) {
      .luoi-mon { grid-template-columns:1fr; }
      .logo { font-size:1.2rem; }
      .tieu-de-section h2 { font-size:1.5rem; }
    }

    /* =============================================
       TIỆN ÍCH
    ============================================= */
    .text-center { text-align:center; }
    .mt-8 { margin-top:8px; }
    .mt-16 { margin-top:16px; }
    .mt-32 { margin-top:32px; }

    /* Nút xem thêm */
    .btn-xem-them {
      display:inline-flex; align-items:center; gap:8px;
      padding:12px 32px;
      border:2px solid var(--do);
      color:var(--do);
      border-radius:8px;
      font-weight:700;
      font-size:0.9rem;
      transition:var(--chuyen);
      background:transparent;
    }
    .btn-xem-them:hover {
      background:var(--do);
      color:#fff;
    }

    /* Skeleton loading */
    .skeleton {
      background:linear-gradient(90deg, var(--xam) 25%, var(--vien) 50%, var(--xam) 75%);
      background-size:200% 100%;
      animation:luotSkeleton 1.5s infinite;
      border-radius:8px;
    }
    @keyframes luotSkeleton {
      0% { background-position:200% 0; }
      100% { background-position:-200% 0; }
    }

    /* Dải hình ảnh tự động */
    .dai-hinh {
      overflow:hidden;
      padding:40px 0;
      background:var(--bg-alt);
    }
    .dai-hinh-track {
      display:flex;
      gap:16px;
      animation:luotHinh 30s linear infinite;
      width:max-content;
    }
    .dai-hinh:hover .dai-hinh-track { animation-play-state:paused; }
    @keyframes luotHinh { 0%{transform:translateX(0)} 100%{transform:translateX(-50%)} }
    .dai-hinh-item {
      width:200px; height:140px;
      border-radius:var(--radius);
      overflow:hidden;
      flex-shrink:0;
      box-shadow:var(--bong);
    }
    .dai-hinh-item img {
      width:100%; height:100%;
      object-fit:cover;
      transition:transform 0.3s;
    }
    .dai-hinh-item:hover img { transform:scale(1.05); }
  </style>
</head>
