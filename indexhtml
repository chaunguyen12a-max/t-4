============================================= */
var oTim, ketQuaTim;

function hienKetQua(tu) {
  if (!oTim || !ketQuaTim) return;

  var query = tu.trim().toLowerCase();

  if (query.length < 1) {
    ketQuaTim.classList.remove('hien');
    oTim.setAttribute('aria-expanded', 'false');
    return;
  }

  var dsLoc = dsMon.filter(function(m) {
    return m.ten.toLowerCase().indexOf(query) !== -1 ||
           m.vung.toLowerCase().indexOf(query) !== -1 ||
           m.mo_ta.toLowerCase().indexOf(query) !== -1;
  });

  if (dsLoc.length === 0) {
    ketQuaTim.innerHTML = '<div class="tim-rong">Không tìm thấy món "' + tu + '"</div>';
  } else {
    var html = '';
    dsLoc.slice(0, 6).forEach(function(mon) {
      html += '<div class="item-tim" role="option" tabindex="0" data-id="' + mon.id + '">';
      html += '<div class="item-tim-anh"><img src="' + mon.anh + '" alt="' + mon.ten + '" loading="lazy"></div>';
      html += '<div><div class="item-tim-ten">' + mon.ten + '</div>';
      html += '<div class="item-tim-tag">📍 ' + mon.vung + '</div></div>';
      html += '</div>';
    });
    ketQuaTim.innerHTML = html;

    ketQuaTim.querySelectorAll('.item-tim').forEach(function(item) {
      item.addEventListener('click', function() {
        var id = parseInt(this.dataset.id, 10);
        ketQuaTim.classList.remove('hien');
        oTim.value = '';
        oTim.setAttribute('aria-expanded', 'false');
        moModal(id);
      });
    });
  }

  ketQuaTim.classList.add('hien');
  oTim.setAttribute('aria-expanded', 'true');
}

var hienKetQuaDebounce = debounce(function() {
  if (oTim) hienKetQua(oTim.value);
