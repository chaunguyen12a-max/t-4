function moModalLeHoi(idx) {
  var lh = dsLeHoi[idx];
  if (!lh) return;
  var modal = document.getElementById('modal-le-hoi');
  if (!modal) return;

  var elIcon = document.getElementById('modal-lh-icon');
  var elThang = document.getElementById('modal-lh-thang');
  var elTen = document.getElementById('modal-lh-ten');
  var elDiaDiem = document.getElementById('modal-lh-diadiem');
  var elMoTa = document.getElementById('modal-lh-mota');
  var elAmThuc = document.getElementById('modal-lh-amthuc');
  var elYNghia = document.getElementById('modal-lh-ynghia');

  if (elIcon) elIcon.textContent = lh.icon;
  if (elThang) elThang.textContent = '📅 ' + lh.thang;
  if (elTen) elTen.textContent = lh.ten;
  if (elDiaDiem) elDiaDiem.textContent = lh.dia_diem;
  if (elMoTa) elMoTa.textContent = lh.mo_ta;
  if (elAmThuc) elAmThuc.textContent = lh.am_thuc;
  if (elYNghia) elYNghia.textContent = lh.y_nghia;

  modal.classList.add('hien');
  modal.setAttribute('aria-hidden', 'false');
  document.body.classList.add('khoa-cuon');
}

function dongModalLeHoi() {
  var modal = document.getElementById('modal-le-hoi');
  if (!modal) return;
  modal.classList.remove('hien');
  modal.setAttribute('aria-hidden', 'true');
  document.body.classList.remove('khoa-cuon');
}

